generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  USER
  AFFILIATE
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
  CLOSED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRADE_BUY
  TRADE_SELL
  COMMISSION
  AUCTION_FEE
  AFFILIATE_COMMISSION
  AFFILIATE_PAYOUT
  PLATFORM_FEE
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum AuctionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ProviderType {
  OPENAI
  ANTHROPIC
  GOOGLE
  MISTRAL
  META
  COHERE
  CUSTOM
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DepositMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CRYPTO
  PLATFORM_CREDIT
}

enum WithdrawalMethod {
  BANK_TRANSFER
  CRYPTO
  PLATFORM_CREDIT
}

enum NotificationType {
  ORDER_FILLED
  AUCTION_WON
  AUCTION_OUTBID
  PRICE_ALERT
  DEPOSIT_CONFIRMED
  WITHDRAWAL_PROCESSED
  KYC_APPROVED
  KYC_REJECTED
  AFFILIATE_COMMISSION
  SYSTEM
}

// ──────────────────────────────────────────────
// IDENTITY & AUTH
// ──────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  emailVerified   DateTime?
  name            String?
  username        String        @unique
  passwordHash    String
  image           String?
  role            UserRole      @default(USER)
  status          AccountStatus @default(PENDING_VERIFICATION)
  phone           String?
  country         String?
  referralCode    String        @unique @default(cuid())
  referredById    String?
  referredBy      User?         @relation("referrals", fields: [referredById], references: [id])
  referrals       User[]        @relation("referrals")
  twoFactorEnabled Boolean      @default(false)
  twoFactorSecret String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  accounts        Account[]
  sessions        Session[]
  wallet          Wallet?
  kycRecord       KycRecord?
  orders          Order[]
  auctionBids     AuctionBid[]
  tradesAsBuyer   Trade[]       @relation("TradeBuyer")
  tradesAsSeller  Trade[]       @relation("TradeSeller")
  notifications   Notification[]
  affiliateProfile AffiliateProfile?
  blogPosts       BlogPost[]
  auditLogs       AuditLog[]
  apiKeys         ApiKey[]

  @@index([email])
  @@index([username])
  @@index([referralCode])
  @@index([status])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model KycRecord {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          KycStatus @default(NOT_SUBMITTED)
  fullName        String?
  dateOfBirth     DateTime?
  documentType    String?
  documentNumber  String?
  documentFront   String?
  documentBack    String?
  selfieUrl       String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ──────────────────────────────────────────────
// WALLET & LEDGER
// ──────────────────────────────────────────────

model Wallet {
  id             String    @id @default(cuid())
  userId         String    @unique
  balanceUsd     Decimal   @default(0) @db.Decimal(18, 2)
  balanceCredits Decimal   @default(0) @db.Decimal(18, 4)
  frozenUsd      Decimal   @default(0) @db.Decimal(18, 2)
  frozenCredits  Decimal   @default(0) @db.Decimal(18, 4)
  totalDeposited Decimal   @default(0) @db.Decimal(18, 2)
  totalWithdrawn Decimal   @default(0) @db.Decimal(18, 2)
  totalTraded    Decimal   @default(0) @db.Decimal(18, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  deposits       Deposit[]
  withdrawals    Withdrawal[]

  @@index([userId])
}

model Transaction {
  id             String            @id @default(cuid())
  walletId       String
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  amountUsd      Decimal           @db.Decimal(18, 2)
  amountCredits  Decimal           @db.Decimal(18, 4)
  creditProvider ProviderType?
  referenceId    String?
  referenceType  String?
  description    String?           @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now())
  completedAt    DateTime?
  wallet         Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([referenceId])
}

model Deposit {
  id          String            @id @default(cuid())
  walletId    String
  userId      String
  amountUsd   Decimal           @db.Decimal(18, 2)
  method      DepositMethod
  status      TransactionStatus @default(PENDING)
  externalRef String?           @unique
  metadata    Json?
  createdAt   DateTime          @default(now())
  completedAt DateTime?
  wallet      Wallet            @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([status])
}

model Withdrawal {
  id          String            @id @default(cuid())
  walletId    String
  userId      String
  amountUsd   Decimal           @db.Decimal(18, 2)
  method      WithdrawalMethod
  status      TransactionStatus @default(PENDING)
  destination String
  network     String?
  externalRef String?           @unique
  metadata    Json?
  createdAt   DateTime          @default(now())
  completedAt DateTime?
  wallet      Wallet            @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([status])
}

// ──────────────────────────────────────────────
// TRADING - PROVIDERS & PRODUCTS
// ──────────────────────────────────────────────

model Provider {
  id          String       @id @default(cuid())
  type        ProviderType
  name        String
  displayName String
  logoUrl     String?
  description String?      @db.Text
  websiteUrl  String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    CreditProduct[]

  @@index([type])
  @@index([isActive])
}

model CreditProduct {
  id           String   @id @default(cuid())
  providerId   String
  name         String
  slug         String   @unique
  providerType ProviderType
  faceValueUsd Decimal  @db.Decimal(10, 2)
  sellPriceUsd Decimal  @db.Decimal(10, 4)
  creditUnit   String
  creditAmount Decimal  @db.Decimal(18, 4)
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  provider     Provider @relation(fields: [providerId], references: [id])
  orders       Order[]
  auctionItems Auction[]

  @@index([providerId])
  @@index([providerType])
  @@index([isActive])
  @@index([slug])
}

// ──────────────────────────────────────────────
// TRADING - ORDER BOOK
// ──────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  userId         String
  productId      String
  side           OrderSide
  type           OrderType
  status         OrderStatus @default(OPEN)
  pricePerUnit   Decimal     @db.Decimal(18, 6)
  quantity       Decimal     @db.Decimal(18, 4)
  filledQuantity Decimal     @default(0) @db.Decimal(18, 4)
  totalValue     Decimal     @db.Decimal(18, 2)
  filledValue    Decimal     @default(0) @db.Decimal(18, 2)
  feeUsd         Decimal     @default(0) @db.Decimal(18, 4)
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id])
  product        CreditProduct @relation(fields: [productId], references: [id])
  fills          OrderFill[]

  @@index([userId])
  @@index([productId, side, status])
  @@index([productId, side, pricePerUnit, createdAt])
  @@index([status, createdAt])
}

model OrderFill {
  id          String   @id @default(cuid())
  orderId     String
  buyOrderId  String?
  sellOrderId String?
  price       Decimal  @db.Decimal(18, 6)
  quantity    Decimal  @db.Decimal(18, 4)
  value       Decimal  @db.Decimal(18, 2)
  feeUsd      Decimal  @db.Decimal(18, 4)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model Trade {
  id           String   @id @default(cuid())
  buyerId      String
  sellerId     String
  productId    String
  quantity     Decimal  @db.Decimal(18, 4)
  pricePerUnit Decimal  @db.Decimal(18, 6)
  totalValue   Decimal  @db.Decimal(18, 2)
  buyerFee     Decimal  @db.Decimal(18, 4)
  sellerFee    Decimal  @db.Decimal(18, 4)
  source       String   @default("orderbook")
  referenceId  String?
  createdAt    DateTime @default(now())
  buyer        User     @relation("TradeBuyer", fields: [buyerId], references: [id])
  seller       User     @relation("TradeSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
  @@index([createdAt])
  @@index([source])
}

// ──────────────────────────────────────────────
// TRADING - AUCTIONS
// ──────────────────────────────────────────────

model Auction {
  id           String        @id @default(cuid())
  sellerId     String
  productId    String
  quantity     Decimal       @db.Decimal(18, 4)
  startPrice   Decimal       @db.Decimal(18, 6)
  currentPrice Decimal       @db.Decimal(18, 6)
  reservePrice Decimal?      @db.Decimal(18, 6)
  status       AuctionStatus @default(PENDING)
  startsAt     DateTime
  endsAt       DateTime
  winningBidId String?       @unique
  bidCount     Int           @default(0)
  feeUsd       Decimal       @default(0) @db.Decimal(18, 4)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  product      CreditProduct @relation(fields: [productId], references: [id])
  bids         AuctionBid[]

  @@index([status, endsAt])
  @@index([productId])
  @@index([sellerId])
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(18, 6)
  quantity  Decimal  @db.Decimal(18, 4)
  isWinning Boolean  @default(false)
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([auctionId])
  @@index([userId])
  @@index([amount, createdAt])
}

// ──────────────────────────────────────────────
// CONTENT - BLOG
// ──────────────────────────────────────────────

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  color       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  posts       BlogPost[]

  @@index([slug])
}

model BlogPost {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  excerpt        String?        @db.Text
  content        String         @db.Text
  coverImage     String?
  authorId       String
  categoryId     String
  status         BlogPostStatus @default(DRAFT)
  tags           String         @default("")
  seoTitle       String?
  seoDescription String?
  viewCount      Int            @default(0)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  author         User           @relation(fields: [authorId], references: [id])
  category       BlogCategory   @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
}

// ──────────────────────────────────────────────
// CONTENT - LANDING PAGE CMS
// ──────────────────────────────────────────────

model LandingSection {
  id         String   @id @default(cuid())
  sectionKey String   @unique
  title      String?
  content    Json?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sectionKey])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  avatarUrl String?
  content   String   @db.Text
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isActive])
}

// ──────────────────────────────────────────────
// AFFILIATE SYSTEM
// ──────────────────────────────────────────────

model AffiliateProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  commissionRate Decimal  @default(0.02) @db.Decimal(5, 4)
  totalReferrals Int      @default(0)
  totalEarnings  Decimal  @default(0) @db.Decimal(18, 2)
  totalPaid      Decimal  @default(0) @db.Decimal(18, 2)
  pendingBalance Decimal  @default(0) @db.Decimal(18, 2)
  tier           String   @default("standard")
  isActive       Boolean  @default(true)
  paymentMethod  String?
  paymentDetails Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions    AffiliateCommission[]
  payouts        AffiliatePayout[]
  referrals      Referral[]

  @@index([userId])
  @@index([tier])
}

model Referral {
  id             String           @id @default(cuid())
  affiliateId    String
  referredUserId String
  status         String           @default("pending")
  convertedAt    DateTime?
  createdAt      DateTime         @default(now())
  affiliate      AffiliateProfile @relation(fields: [affiliateId], references: [id])

  @@unique([affiliateId, referredUserId])
  @@index([affiliateId])
  @@index([status])
}

model AffiliateCommission {
  id            String           @id @default(cuid())
  affiliateId   String
  referralId    String?
  sourceTradeId String?
  sourceUserId  String
  amountUsd     Decimal          @db.Decimal(18, 4)
  status        String           @default("pending")
  createdAt     DateTime         @default(now())
  confirmedAt   DateTime?
  affiliate     AffiliateProfile @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
}

model AffiliatePayout {
  id          String           @id @default(cuid())
  affiliateId String
  amountUsd   Decimal          @db.Decimal(18, 2)
  status      String           @default("pending")
  method      String?
  reference   String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
}

// ──────────────────────────────────────────────
// ADMIN & PLATFORM
// ──────────────────────────────────────────────

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?  @db.Text
  category    String   @default("general")
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@index([category])
}

model CommissionConfig {
  id              String   @id @default(cuid())
  tradeCommission Decimal  @default(0.0025) @db.Decimal(6, 4)
  auctionFee      Decimal  @default(1.00) @db.Decimal(10, 2)
  minCommission   Decimal  @default(0.01) @db.Decimal(10, 4)
  maxCommission   Decimal  @default(100.00) @db.Decimal(10, 2)
  affiliateRate   Decimal  @default(0.02) @db.Decimal(6, 4)
  isActive        Boolean  @default(true)
  effectiveFrom   DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([isActive, effectiveFrom])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([type])
}

// ──────────────────────────────────────────────
// API KEYS
// ──────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  prefix      String
  permissions String    @default("read")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prefix])
}

// ──────────────────────────────────────────────
// PLATFORM STATS CACHE
// ──────────────────────────────────────────────

model PlatformStats {
  id                 String   @id @default("singleton")
  totalVolumeUsd     Decimal  @default(0) @db.Decimal(18, 2)
  totalTrades        Int      @default(0)
  activeTraders      Int      @default(0)
  totalCreditsTraded Decimal  @default(0) @db.Decimal(18, 4)
  totalUsers         Int      @default(0)
  updatedAt          DateTime @updatedAt
}
